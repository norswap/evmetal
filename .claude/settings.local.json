{
    "env": {
        "CX_CACHE_DIR": ".cx-cache"
    },
    "permissions": {
        "allow": [
            "Bash(awk:*)",
            "Bash(cat:*)",
            "Bash(cx:*)",
            "Bash(find:*)",
            "Bash(grep:*)",
            "Bash(head:*)",
            "Bash(sed:*)",
            "Bash(sort:*)",
            "Bash(tail:*)",
            "Bash(touch:*)",
            "Bash(uniq:*)",
            "Bash(wc:*)",
            "Bash(bun add:*)",
            "Bash(bun install:*)",
            "Bash(bun remove:*)",
            "Bash(bun pm ls:*)",
            "Bash(bun --hot index.html)",
            "Bash(bun --version:*)",
            "Bash(bunx --version:*)",
            "Bash(bunx npm view:*)",
            "Bash(gh repo:*)",
            "Bash(gh search:*)",
            "Bash(git ls-remote:*)",
            "Bash(make:*)",
            "Read(/tmp/claude/*)",
            "Skill(*)",
            "WebSearch",
            "WebFetch",
            "WebFetch(domain:github.com)",
            "WebFetch(domain:api.github.com)",
            "WebFetch(domain:raw.githubusercontent.com)"
        ],
        "deny": []
    },
    "sandbox": {
        "enabled": true,
        "autoAllowBashIfSandboxed": true
    },
    "enabledMcpjsonServers": ["playwright"]
}
