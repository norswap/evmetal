{
    "$schema": "https://v2-9-6.turborepo.dev/schema.json",
    "tasks": {
        "//#setup:bun": {
            "cache": false
        },
        "setup": {
            "dependsOn": ["^setup", "//#setup:bun"],
            "cache": false
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"],
            "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/shared/tsconfig.base.json"]
        },
        "transit": {
            "dependsOn": ["^transit"]
        },
        "clean": {
            "cache": false
        },
        "make": {
            "dependsOn": ["^make"]
        },
        "typecheck": {
            "dependsOn": ["^build"]
        },
        "lint": {
            "dependsOn": ["^transit"],
            "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/shared/biome.jsonc"]
        },
        "lintfix": {
            "dependsOn": ["^transit"],
            "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/shared/biome.jsonc"]
        },
        "test": {
            "dependsOn": ["^transit"]
        }
    }
}
