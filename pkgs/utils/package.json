{
    "name": "@norswap/utils",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "imports": {
        "#src/*": "./src/*"
    },
    "exports": {
        ".": {
            "bun": {
                "types": "./src/index.ts",
                "default": "./src/index.ts"
            },
            "development": {
                "types": "./src/index.ts",
                "default": "./src/index.ts"
            },
            "default": {
                "types": "./dist/src/index.d.ts",
                "default": "./dist/src/index.js"
            }
        }
    },
    "files": [
        "src",
        "dist",
        "package.json"
    ],
    "scripts": {
        "build": "make clean && bun build.ts all",
        "lint": "bunx biome check",
        "lintfix": "bunx sort-package-json && bunx biome check --fix --unsafe",
        "make": "make",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@bunup/dts": "catalog:",
        "@types/bun": "catalog:",
        "typescript": "catalog:"
    }
}
